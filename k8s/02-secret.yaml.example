# TEMPLATE Secret - file ini AMAN untuk di-commit ke Git karena tidak berisi
# kredensial asli apapun, cuma placeholder.
#
# CARA PAKAI:
# 1. Copy file ini, rename jadi "02-secret.yaml" (hilangkan ".example")
# 2. Isi MAIL_USERNAME dan MAIL_PASSWORD dengan nilai base64 kredensial asli kamu:
#      [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("emailkamu@gmail.com"))
# 3. File "02-secret.yaml" (tanpa .example) sudah otomatis di-ignore oleh .gitignore,
#    jadi aman kalaupun sudah diisi kredensial asli - tidak akan ikut ter-commit.
apiVersion: v1
kind: Secret
metadata:
  name: email-credentials
  namespace: microservices-siti
type: Opaque
data:
  MAIL_USERNAME: PISI_BASE64_EMAIL_KAMU_DI_SINI
  MAIL_PASSWORD: ISI_BASE64_APP_PASSWORD_DI_SINI
